{
  "Logging": {
    "LogLevel": {
      "Default": "Information",
      "Microsoft.AspNetCore": "Warning"
    },
    "Console": {
      "FormatterName": "json",
      "FormatterOptions": {
        "IncludeScopes": true
      }
    }
  },
  "AllowedHosts": "*",
  "OrderProcessing": {
    "MinDelayMs": 100,
    "MaxDelayMs": 500,
    "RateLimitPerMinute": 100
  }
}
